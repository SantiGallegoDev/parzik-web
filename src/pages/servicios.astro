---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Servicios — Parzik">
  <Navbar />

  <!-- Hero -->
  <section class="page-hero">
    <div class="hero-bg">
      <div class="circle circle-1"></div>
      <div class="circle circle-2"></div>
    </div>
    <div class="container">
      <p class="tag" data-animate="blur">Lo que hacemos</p>
      <h1 data-animate="fade-up" data-delay="100">Tu negocio merece<br /><span class="highlight">una web que venda</span></h1>
      <p class="subtitle" data-animate="fade-up" data-delay="200">Diseñamos y desarrollamos páginas web y software que convierten visitantes en clientes reales.</p>
      <div class="hero-cta" data-animate="fade-up" data-delay="300">
        <a href="#desarrollo-web" class="btn-primary">Ver servicios</a>
      </div>
    </div>
  </section>

  <!-- Números de impacto -->
  <section class="impact">
    <div class="container">
      <div class="impact-grid" data-stagger>
        <div class="impact-item">
          <span class="impact-number">50+</span>
          <span class="impact-label">Proyectos entregados</span>
        </div>
        <div class="impact-item">
          <span class="impact-number">3x</span>
          <span class="impact-label">Más conversión que un sitio genérico</span>
        </div>
        <div class="impact-item">
          <span class="impact-number">&lt;2s</span>
          <span class="impact-label">Tiempo de carga</span>
        </div>
        <div class="impact-item">
          <span class="impact-number">99.9%</span>
          <span class="impact-label">Disponibilidad</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ======== SERVICIO 1: DESARROLLO WEB ======== -->

  <!-- Intro Desarrollo Web -->
  <section class="service-intro" id="desarrollo-web">
    <div class="container">
      <div class="service-intro-content" data-animate="fade-up">
        <p class="tag">Servicio 01</p>
        <h2>Desarrollo Web</h2>
        <p class="service-lead">Creamos páginas web rápidas, modernas y diseñadas para que tu negocio crezca. No hacemos sitios por hacer — cada proyecto tiene un objetivo claro: <strong>generar más clientes.</strong></p>
      </div>
    </div>
  </section>

  <!-- Tipos de web -->
  <section class="web-types">
    <div class="container">
      <h3 class="section-subtitle" data-animate="fade-up">¿Qué tipo de web necesitas?</h3>
      <div class="types-grid" data-stagger>

        <div class="type-card">
          <div class="type-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h4>Página Corporativa</h4>
          <p>Presencia profesional para tu empresa. Multi-página, adaptable a celular, con formularios de contacto y lista para aparecer en Google.</p>
          <span class="type-ideal">Ideal para: empresas, estudios, consultorios</span>
        </div>

        <div class="type-card">
          <div class="type-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <h4>Landing Page</h4>
          <p>Una sola página enfocada en un objetivo: que el visitante te contacte, se registre o compre. Rápida, directa y efectiva.</p>
          <span class="type-ideal">Ideal para: lanzamientos, campañas, captación</span>
        </div>

        <div class="type-card featured">
          <div class="type-badge">Popular</div>
          <div class="type-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
          </div>
          <h4>Tienda Online</h4>
          <p>Vende tus productos 24/7 con una tienda optimizada. Pagos seguros, gestión de inventario y experiencia de compra fluida.</p>
          <span class="type-ideal">Ideal para: marcas, emprendimientos, retail</span>
        </div>

      </div>
    </div>
  </section>

  <!-- ¿Qué incluye? -->
  <section class="whats-included">
    <div class="container">
      <div class="included-header" data-animate="fade-up">
        <h3 class="section-subtitle">Lo que puedes esperar</h3>
        <p class="included-sub">Dependiendo del tipo de proyecto, estos son algunos de los elementos que podemos incluir.</p>
      </div>
      <div class="included-grid" data-stagger>
        <div class="included-item">
          <div class="included-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <span>Diseño personalizado</span>
        </div>
        <div class="included-item">
          <div class="included-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <span>Adaptable a celular y tablet</span>
        </div>
        <div class="included-item">
          <div class="included-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <span>Velocidad de carga optimizada</span>
        </div>
        <div class="included-item">
          <div class="included-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <span>Preparada para Google (SEO)</span>
        </div>
        <div class="included-item">
          <div class="included-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <span>Certificado de seguridad (SSL)</span>
        </div>
        <div class="included-item">
          <div class="included-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <span>Formularios de contacto</span>
        </div>
        <div class="included-item">
          <div class="included-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <span>Dominio y hosting</span>
        </div>
        <div class="included-item">
          <div class="included-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <span>Panel de administración</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA intermedio -->
  <section class="mid-cta">
    <div class="container">
      <div class="mid-cta-card" data-animate="fade-up">
        <h3>¿Necesitas una página web?</h3>
        <p>Cotiza tu proyecto en menos de 2 minutos con nuestro cotizador interactivo.</p>
        <a href="/cotizador" class="btn-primary">Cotizar mi web</a>
      </div>
    </div>
  </section>

  <!-- ======== SERVICIO 2: SOFTWARE A MEDIDA ======== -->

  <!-- Intro Software -->
  <section class="service-intro alt" id="software-medida">
    <div class="container">
      <div class="service-intro-content" data-animate="fade-up">
        <p class="tag">Servicio 02</p>
        <h2>Software a Medida</h2>
        <p class="service-lead">Si tu equipo pierde tiempo en tareas repetitivas, hojas de cálculo o herramientas que no se conectan entre sí, necesitas un sistema hecho a la medida de tu operación.</p>
      </div>
    </div>
  </section>

  <!-- Problemas que resolvemos -->
  <section class="problems">
    <div class="container">
      <h3 class="section-subtitle" data-animate="fade-up">Problemas que resolvemos</h3>
      <div class="problems-grid" data-stagger>
        <div class="problem-card">
          <div class="problem-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
          </div>
          <h4>Procesos manuales lentos</h4>
          <p>Automatizamos lo que tu equipo hace a mano: reportes, facturas, notificaciones, aprobaciones.</p>
        </div>
        <div class="problem-card">
          <div class="problem-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
          </div>
          <h4>Herramientas desconectadas</h4>
          <p>Conectamos tus sistemas para que la información fluya automáticamente entre ellos.</p>
        </div>
        <div class="problem-card">
          <div class="problem-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
          </div>
          <h4>Software genérico costoso</h4>
          <p>Dejas de pagar licencias mensuales por funciones que no usas. Tu herramienta, tus reglas.</p>
        </div>
        <div class="problem-card">
          <div class="problem-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
          </div>
          <h4>Falta de visibilidad</h4>
          <p>Dashboards en tiempo real para saber exactamente cómo va tu negocio, sin depender de Excel.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Qué construimos -->
  <section class="what-we-build">
    <div class="container">
      <h3 class="section-subtitle" data-animate="fade-up">¿Qué podemos construirte?</h3>
      <div class="build-grid" data-stagger>
        <div class="build-item">
          <div class="build-number">01</div>
          <div class="build-content">
            <h4>Sistemas de gestión (CRM)</h4>
            <p>Gestiona clientes, ventas y seguimiento comercial desde un solo lugar, diseñado para tu industria.</p>
          </div>
        </div>
        <div class="build-item">
          <div class="build-number">02</div>
          <div class="build-content">
            <h4>Paneles de control</h4>
            <p>Visualiza métricas, ventas y rendimiento de tu equipo en tiempo real con alertas automáticas.</p>
          </div>
        </div>
        <div class="build-item">
          <div class="build-number">03</div>
          <div class="build-content">
            <h4>Automatizaciones</h4>
            <p>Facturación automática, envío de correos, generación de reportes y flujos de aprobación sin intervención manual.</p>
          </div>
        </div>
        <div class="build-item">
          <div class="build-number">04</div>
          <div class="build-content">
            <h4>Integraciones</h4>
            <p>Conectamos tu sistema con WhatsApp, pasarelas de pago, Google Sheets, correo y cualquier herramienta que uses.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Resultados -->
  <section class="results">
    <div class="container">
      <h3 class="section-subtitle center" data-animate="fade-up">Resultados que puedes esperar</h3>
      <div class="results-grid" data-stagger>
        <div class="result-card">
          <span class="result-number">-70%</span>
          <p>Menos tiempo en tareas operativas</p>
        </div>
        <div class="result-card">
          <span class="result-number">+15h</span>
          <p>Horas semanales que recupera tu equipo</p>
        </div>
        <div class="result-card">
          <span class="result-number">$0</span>
          <p>Licencias mensuales — es tu software</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA intermedio 2 -->
  <section class="mid-cta">
    <div class="container">
      <div class="mid-cta-card alt" data-animate="fade-up">
        <h3>¿Tu negocio necesita un sistema propio?</h3>
        <p>Cuéntanos qué quieres automatizar y te proponemos una solución.</p>
        <a href="mailto:hola@parzik.com" class="btn-primary">Hablemos</a>
      </div>
    </div>
  </section>

  <!-- Comparación -->
  <section class="comparison">
    <div class="container">
      <div class="comparison-header" data-animate="fade-up">
        <p class="tag">¿Por qué elegirnos?</p>
        <h2>Plantillas genéricas <span class="highlight">vs.</span> Hecho a medida</h2>
      </div>
      <div class="comparison-grid" data-stagger>
        <div class="comparison-card generic">
          <h3>Solución genérica</h3>
          <ul>
            <li class="con">Pagas por funciones que nunca usas</li>
            <li class="con">Tu equipo se adapta a la herramienta</li>
            <li class="con">Costos mensuales que crecen con cada usuario</li>
            <li class="con">Límites de personalización</li>
            <li class="con">Diseño igual al de tu competencia</li>
          </ul>
        </div>
        <div class="comparison-card custom">
          <div class="custom-badge">Parzik</div>
          <h3>Hecho para ti</h3>
          <ul>
            <li class="pro">Solo lo que tu negocio necesita</li>
            <li class="pro">La herramienta se adapta a tu equipo</li>
            <li class="pro">Inversión única, sin sorpresas</li>
            <li class="pro">Crece contigo sin límites</li>
            <li class="pro">Diseño único que refleja tu marca</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="final-cta">
    <div class="container">
      <div class="final-cta-card" data-animate="scale">
        <p class="tag">Da el primer paso</p>
        <h2>¿Listo para hacer crecer tu negocio?</h2>
        <p class="final-cta-sub">Agenda una llamada gratuita y te mostramos cómo podemos ayudarte.</p>
        <div class="final-cta-actions">
          <a href="/cotizador" class="btn-primary">Cotiza tu proyecto</a>
          <a href="mailto:hola@parzik.com" class="btn-secondary">Escríbenos</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .tag {
    color: var(--lime-green);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-xs);
  }

  .highlight {
    color: var(--lime-green);
  }

  .section-subtitle {
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    font-weight: 700;
    margin-bottom: var(--space-lg);
  }

  .section-subtitle.center {
    text-align: center;
  }

  /* Hero BG */
  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .circle {
    position: absolute;
    border-radius: 50%;
    background: var(--lime-green);
  }

  .circle-1 {
    width: 450px;
    height: 450px;
    top: -120px;
    left: -120px;
    opacity: 0.04;
  }

  .circle-2 {
    width: 300px;
    height: 300px;
    bottom: -60px;
    right: -60px;
    opacity: 0.03;
  }

  /* Page Hero */
  .page-hero {
    position: relative;
    padding: 140px var(--space-lg) var(--space-2xl);
    text-align: center;
    background: linear-gradient(180deg, #0A0A0A 0%, #111219 100%);
    overflow: hidden;
  }

  .page-hero h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    margin-bottom: var(--space-sm);
    line-height: 1.15;
  }

  .subtitle {
    color: rgba(255, 255, 255, 0.55);
    font-size: 1.0625rem;
    max-width: 500px;
    margin: 0 auto;
    font-weight: 300;
    line-height: 1.7;
  }

  .hero-cta {
    margin-top: var(--space-lg);
  }

  /* Impact */
  .impact {
    padding: var(--space-xl) var(--space-lg);
    background: linear-gradient(180deg, #111219 0%, #0A0A0A 100%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .impact-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
    text-align: center;
  }

  .impact-item {
    padding: var(--space-md);
  }

  .impact-number {
    display: block;
    font-family: var(--font-heading);
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--lime-green);
    margin-bottom: 4px;
  }

  .impact-label {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.8125rem;
    font-weight: 300;
  }

  /* Service Intro */
  .service-intro {
    padding: var(--space-2xl) var(--space-lg) var(--space-lg);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .service-intro.alt {
    background: linear-gradient(180deg, rgba(17, 18, 25, 0.4) 0%, transparent 100%);
  }

  .service-intro h2 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    margin-bottom: var(--space-sm);
  }

  .service-lead {
    color: rgba(255, 255, 255, 0.55);
    font-size: 1.0625rem;
    max-width: 640px;
    line-height: 1.8;
    font-weight: 300;
  }

  .service-lead strong {
    color: var(--lime-green);
    font-weight: 600;
  }

  /* Web Types */
  .web-types {
    padding: var(--space-lg) var(--space-lg) var(--space-2xl);
  }

  .types-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .type-card {
    position: relative;
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 16px;
    padding: var(--space-xl) var(--space-lg);
    transition: border-color 0.3s, transform 0.3s, background 0.3s;
  }

  .type-card:hover {
    border-color: rgba(203, 232, 80, 0.2);
    transform: translateY(-4px);
    background: rgba(255, 255, 255, 0.04);
  }

  .type-card.featured {
    border-color: rgba(203, 232, 80, 0.2);
    background: rgba(203, 232, 80, 0.03);
  }

  .type-badge {
    position: absolute;
    top: -10px;
    right: var(--space-sm);
    background: var(--lime-green);
    color: var(--deep-ocean);
    font-size: 0.6875rem;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 4px;
  }

  .type-icon {
    color: var(--lime-green);
    margin-bottom: var(--space-md);
  }

  .type-card h4 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: var(--space-xs);
  }

  .type-card > p {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.9375rem;
    line-height: 1.7;
    font-weight: 300;
    margin-bottom: var(--space-md);
  }

  .type-ideal {
    display: block;
    color: var(--lime-green);
    font-size: 0.8125rem;
    font-weight: 500;
    padding-top: var(--space-sm);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  /* What's Included */
  .whats-included {
    padding: var(--space-2xl) var(--space-lg);
    background: rgba(255, 255, 255, 0.015);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .included-header {
    margin-bottom: var(--space-lg);
  }

  .included-sub {
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.9375rem;
    font-weight: 300;
  }

  .included-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-sm) var(--space-xl);
  }

  .included-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
  }

  .included-icon {
    color: var(--lime-green);
    flex-shrink: 0;
  }

  .included-item span {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9375rem;
    font-weight: 400;
  }

  /* Mid CTA */
  .mid-cta {
    padding: var(--space-xl) var(--space-lg);
  }

  .mid-cta-card {
    background: linear-gradient(135deg, rgba(203, 232, 80, 0.05) 0%, rgba(255, 255, 255, 0.02) 100%);
    border: 1px solid rgba(203, 232, 80, 0.12);
    border-radius: 16px;
    padding: var(--space-xl) var(--space-2xl);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .mid-cta-card::before {
    content: '';
    position: absolute;
    top: -60%;
    right: -15%;
    width: 250px;
    height: 250px;
    background: radial-gradient(circle, rgba(203, 232, 80, 0.06) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

