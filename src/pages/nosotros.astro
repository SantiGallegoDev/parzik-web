---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Nosotros — Parzik">
  <Navbar />

  <section class="page-hero">
    <div class="hero-bg">
      <div class="circle circle-1"></div>
      <div class="circle circle-2"></div>
    </div>
    <div class="container">
      <p class="tag" data-animate="blur">Quienes somos</p>
      <h1 data-animate="fade-up" data-delay="100">Tecnología con propósito</h1>
      <p class="subtitle" data-animate="fade-up" data-delay="200">Somos una agencia híbrida que une desarrollo de software y marketing digital para crear soluciones que realmente impactan.</p>
    </div>
  </section>

  <section class="mission">
    <div class="container">
      <div class="mission-grid">
        <div class="mission-card" data-animate="fade-up">
          <div class="mission-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
          </div>
          <h3>Misión</h3>
          <p>Impulsar negocios a través de soluciones digitales integrales que combinan la precisión del software con la creatividad del marketing.</p>
        </div>
        <div class="mission-card" data-animate="fade-up" data-delay="100">
          <div class="mission-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </div>
          <h3>Visión</h3>
          <p>Ser la agencia de referencia en Latinoamérica donde tecnología y marketing convergen para transformar empresas.</p>
        </div>
        <div class="mission-card" data-animate="fade-up" data-delay="200">
          <div class="mission-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <h3>Valores</h3>
          <p>Precisión, innovación, transparencia y compromiso con resultados medibles para cada cliente.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="story">
    <div class="container">
      <div class="story-grid">
        <div class="story-text" data-animate="fade-left">
          <p class="tag">Nuestra historia</p>
          <h2>Nacimos de la necesidad de hacer las cosas <span class="highlight">diferente</span></h2>
          <p class="story-desc">Parzik nació cuando un grupo de desarrolladores y estrategas de marketing se dieron cuenta de que los mejores resultados digitales ocurren cuando código y creatividad trabajan juntos desde el día uno.</p>
          <p class="story-desc">No somos una agencia de marketing que subcontrata desarrollo, ni un estudio de software que ignora la estrategia. Somos ambos, integrados en un solo equipo.</p>
        </div>
        <div class="story-stats" data-animate="fade-right">
          <div class="big-stat">
            <span class="big-num">3+</span>
            <span class="big-label">Años construyendo soluciones digitales</span>
          </div>
          <div class="big-stat">
            <span class="big-num">50+</span>
            <span class="big-label">Proyectos entregados exitosamente</span>
          </div>
          <div class="big-stat">
            <span class="big-num">30+</span>
            <span class="big-label">Clientes que confían en nosotros</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="team">
    <div class="container">
      <p class="tag" data-animate="fade-up">El equipo</p>
      <h2 data-animate="fade-up" data-delay="100">Las personas detrás de Parzik</h2>
      <div class="team-grid" data-stagger>
        <div class="team-card">
          <div class="team-photo"><img src="/team/member1.jpg" alt="Carlos Méndez" /></div>
          <h3>Carlos Méndez</h3>
          <span class="team-role">CEO & Fundador</span>
          <p>Estrategia digital y desarrollo de producto con +8 años de experiencia.</p>
        </div>
        <div class="team-card">
          <div class="team-photo"><img src="/team/member2.jpg" alt="Laura Ríos" /></div>
          <h3>Laura Ríos</h3>
          <span class="team-role">Directora de Marketing</span>
          <p>Growth marketing, pauta digital y estrategias de adquisición de clientes.</p>
        </div>
        <div class="team-card">
          <div class="team-photo"><img src="/team/member3.jpg" alt="Diego Vargas" /></div>
          <h3>Diego Vargas</h3>
          <span class="team-role">Lead Developer</span>
          <p>Arquitectura de software, full-stack development y DevOps.</p>
        </div>
        <div class="team-card">
          <div class="team-photo"><img src="/team/member4.jpg" alt="Ana Torres" /></div>
          <h3>Ana Torres</h3>
          <span class="team-role">Directora Creativa</span>
          <p>Branding, UI/UX design y sistemas de diseño escalables.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="values">
    <div class="container">
      <p class="tag" data-animate="fade-up">Por qué elegirnos</p>
      <h2 data-animate="fade-up" data-delay="100">Lo que nos hace diferentes</h2>
      <div class="values-grid" data-stagger>
        <div class="value-card">
          <div class="value-num">01</div>
          <h3>Equipo integrado</h3>
          <p>Desarrolladores y marketers trabajando juntos, no en silos separados.</p>
        </div>
        <div class="value-card">
          <div class="value-num">02</div>
          <h3>Resultados medibles</h3>
          <p>Cada proyecto tiene KPIs claros. Si no se puede medir, no lo hacemos.</p>
        </div>
        <div class="value-card">
          <div class="value-num">03</div>
          <h3>Tecnología moderna</h3>
          <p>Usamos las herramientas más actuales para entregar productos rápidos y escalables.</p>
        </div>
        <div class="value-card">
          <div class="value-num">04</div>
          <h3>Transparencia total</h3>
          <p>Comunicación directa, reportes claros y sin sorpresas en el proceso.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-card" data-animate="scale">
        <h2>Trabajemos juntos</h2>
        <p>Queremos conocer tu proyecto y mostrarte cómo podemos ayudarte a crecer.</p>
        <a href="/contacto" class="btn-primary">Agenda una llamada</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .tag {
    color: var(--lime-green);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-xs);
  }

  .highlight {
    color: var(--lime-green);
  }

  /* Hero BG */
  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .circle {
    position: absolute;
    border-radius: 50%;
    background: var(--lime-green);
  }

  .circle-1 {
    width: 400px;
    height: 400px;
    top: -100px;
    right: -80px;
    opacity: 0.04;
  }

  .circle-2 {
    width: 250px;
    height: 250px;
    bottom: -40px;
    left: -60px;
    opacity: 0.03;
  }

  /* Page Hero */
  .page-hero {
    position: relative;
    padding: 140px var(--space-lg) var(--space-2xl);
    text-align: center;
    background: linear-gradient(180deg, #0A0A0A 0%, #111219 100%);
    overflow: hidden;
  }

  .page-hero h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    margin-bottom: var(--space-sm);
  }

  .subtitle {
    color: rgba(255, 255, 255, 0.5);
    font-size: 1.0625rem;
    max-width: 540px;
    margin: 0 auto;
    font-weight: 300;
    line-height: 1.7;
  }

  /* Mission */
  .mission {
    padding: var(--space-2xl) var(--space-lg);
  }

  .mission-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .mission-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    padding: var(--space-lg);
    transition: border-color 0.3s, background 0.3s;
  }

  .mission-card:hover {
    border-color: rgba(203, 232, 80, 0.15);
    background: rgba(203, 232, 80, 0.03);
  }

  .mission-icon {
    color: var(--lime-green);
    margin-bottom: var(--space-sm);
  }

  .mission-card h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: var(--space-xs);
  }

  .mission-card p {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.9375rem;
    line-height: 1.7;
    font-weight: 300;
  }

  /* Story */
  .story {
    padding: var(--space-xl) var(--space-lg) var(--space-2xl);
    background: radial-gradient(ellipse at 30% 50%, rgba(203, 232, 80, 0.02) 0%, transparent 60%);
  }

  .story-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  .story-text h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.25rem);
    font-weight: 700;
    margin-bottom: var(--space-md);
    line-height: 1.3;
  }

  .story-desc {
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.9375rem;
    line-height: 1.8;
    font-weight: 300;
    margin-bottom: var(--space-sm);
  }

  .story-stats {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .big-stat {
    padding: var(--space-md);
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    transition: border-color 0.3s;
  }

  .big-stat:hover {
    border-color: rgba(203, 232, 80, 0.15);
  }

  .big-num {
    display: block;
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--lime-green);
    line-height: 1;
    margin-bottom: 4px;
  }

  .big-label {
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.875rem;
    font-weight: 300;
  }

  /* Team */
  .team {
    padding: var(--space-2xl) var(--space-lg);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .team h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.25rem);
    font-weight: 700;
    margin-bottom: var(--space-xl);
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
  }

  .team-card {
    text-align: center;
  }

  .team-photo {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: var(--space-sm);
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition: border-color 0.3s;
  }

  .team-card:hover .team-photo {
    border-color: rgba(203, 232, 80, 0.2);
  }

  .team-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(30%);
    transition: filter 0.4s;
  }

  .team-card:hover .team-photo img {
    filter: grayscale(0%);
  }

  .team-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 2px;
  }

  .team-role {
    display: block;
    color: var(--lime-green);
    font-size: 0.8125rem;
    font-weight: 500;
    margin-bottom: var(--space-xs);
  }

  .team-card p {
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.8125rem;
    line-height: 1.6;
    font-weight: 300;
  }

  /* Values */
  .values {
    padding: var(--space-2xl) var(--space-lg);
    background: linear-gradient(180deg, rgba(17, 18, 25, 0.5) 0%, #0A0A0A 100%);
  }

  .values h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.25rem);
    font-weight: 700;
    margin-bottom: var(--space-xl);
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  .value-card {
    padding: var(--space-lg);
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    transition: border-color 0.3s, transform 0.3s, background 0.3s;
  }

  .value-card:hover {
    border-color: rgba(203, 232, 80, 0.15);
    transform: translateY(-4px);
    background: rgba(203, 232, 80, 0.03);
  }

  .value-num {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    color: var(--lime-green);
    font-weight: 700;
    margin-bottom: var(--space-xs);
  }

  .value-card h3 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: var(--space-xs);
  }

  .value-card p {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.9375rem;
    line-height: 1.6;
    font-weight: 300;
  }

  /* CTA */
  .cta-section {
    padding: var(--space-xl) var(--space-lg) var(--space-2xl);
  }

  .cta-card {
    background: linear-gradient(135deg, rgba(203, 232, 80, 0.04) 0%, rgba(255, 255, 255, 0.02) 100%);
    border: 1px solid rgba(203, 232, 80, 0.1);
    border-radius: 16px;
    padding: var(--space-2xl);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .cta-card::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -20%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(203, 232, 80, 0.06) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .cta-card h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.25rem);
    font-weight: 700;
    margin-bottom: var(--space-sm);
  }

  .cta-card p {
    color: rgba(255, 255, 255, 0.55);
    font-size: 1rem;
    margin-bottom: var(--space-lg);
    font-weight: 300;
  }

  .btn-primary {
    display: inline-block;
    background: var(--lime-green);
    color: var(--deep-ocean);
    padding: 14px 32px;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.9375rem;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(203, 232, 80, 0.25);
  }

  @media (max-width: 768px) {
    .mission-grid {
      grid-template-columns: 1fr;
    }

    .story-grid {
      grid-template-columns: 1fr;
    }

    .team-grid {
      grid-template-columns: 1fr 1fr;
    }

    .values-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
