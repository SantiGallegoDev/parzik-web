---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import config from '../data/cotizador-config.json';
---

<Layout title="Cotizador Web — Parzik">
  <Navbar />

  <section class="page-hero">
    <div class="hero-bg">
      <div class="circle circle-1"></div>
      <div class="circle circle-2"></div>
    </div>
    <div class="container">
      <p class="tag" data-animate="blur">Cotizador</p>
      <h1 data-animate="fade-up" data-delay="100">Cotiza tu proyecto</h1>
      <p class="subtitle" data-animate="fade-up" data-delay="200">Responde unas preguntas rapidas y obtene una cotizacion clara, lista para enviar por WhatsApp.</p>
    </div>
  </section>

  <section class="cotizador">
    <div class="container">
      <div class="quoter-card">
        <!-- Progress -->
        <div class="quoter-progress">
          <div class="progress-bar">
            <div class="progress-fill" id="progressFill"></div>
          </div>
          <p class="progress-text" id="progressText">Paso 1 de 10</p>
        </div>

        <!-- Steps container -->
        <div class="quoter-body" id="quoterBody"></div>

        <!-- Navigation -->
        <div class="quoter-nav">
          <button class="btn-secondary" id="btnPrev" style="visibility: hidden;">Anterior</button>
          <button class="btn-primary" id="btnNext">Siguiente</button>
        </div>
      </div>

      <!-- Summary (hidden until last step) -->
      <div class="quoter-summary" id="quoterSummary" style="display: none;">
        <div class="summary-card">
          <h2>Resumen de tu cotizacion</h2>
          <div class="summary-items" id="summaryItems"></div>
          <div class="summary-totals" id="summaryTotals"></div>
          <div class="summary-actions">
            <a class="btn-whatsapp" id="btnWhatsapp" href="#" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Enviar por WhatsApp
            </a>
            <button class="btn-secondary" id="btnNewQuote">Nueva cotizacion</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script type="application/json" id="cotizador-data" set:html={JSON.stringify(config)} />

<script>
  const config = JSON.parse(document.getElementById('cotizador-data').textContent);
  const steps = config.steps;

  let currentStepIndex = 0;
  let selections = {};

  const quoterBody = document.getElementById('quoterBody');
  const quoterSummary = document.getElementById('quoterSummary');
  const progressFill = document.getElementById('progressFill');
  const progressText = document.getElementById('progressText');
  const btnPrev = document.getElementById('btnPrev');
  const btnNext = document.getElementById('btnNext');
  const summaryItems = document.getElementById('summaryItems');
  const summaryTotals = document.getElementById('summaryTotals');
  const btnWhatsapp = document.getElementById('btnWhatsapp');
  const btnNewQuote = document.getElementById('btnNewQuote');

  function getVisibleSteps() {
    return steps.filter(step => {
      if (!step.condition) return true;
      return selections[step.condition.stepId] === step.condition.value;
    });
  }

  function formatPrice(num) {
    return config.currencySymbol + ' ' + num.toLocaleString('es-CO');
  }

  function renderStep() {
    const visible = getVisibleSteps();
    const step = visible[currentStepIndex];
    if (!step) return;

    const total = visible.length;
    const pct = ((currentStepIndex + 1) / (total + 1)) * 100;
    progressFill.style.width = pct + '%';
    progressText.textContent = `Paso ${currentStepIndex + 1} de ${total}`;

    btnPrev.style.visibility = currentStepIndex === 0 ? 'hidden' : 'visible';
    btnNext.textContent = currentStepIndex === total - 1 ? 'Ver resumen' : 'Siguiente';

    let html = `<h3 class="step-title">${step.title}</h3>`;
    html += `<p class="step-desc">${step.description}</p>`;

    if (step.type === 'single-select') {
      html += '<div class="step-options">';
      step.options.forEach(opt => {
        const selected = selections[step.id] === opt.id;
        const priceText = opt.price !== undefined ? formatPrice(opt.price) : '';
        const multiplierText = opt.multiplier !== undefined
          ? (opt.multiplier === 1 ? 'Sin recargo' : opt.multiplier > 1 ? `+${Math.round((opt.multiplier - 1) * 100)}%` : `${Math.round((opt.multiplier - 1) * 100)}%`)
          : '';
        html += `
          <button class="option-card${selected ? ' selected' : ''}" data-step="${step.id}" data-value="${opt.id}">
            <span class="option-label">${opt.label}</span>
            ${priceText ? `<span class="option-price">${priceText}</span>` : ''}
            ${multiplierText ? `<span class="option-price">${multiplierText}</span>` : ''}
            ${opt.description ? `<span class="option-desc">${opt.description}</span>` : ''}
          </button>
        `;
      });
      html += '</div>';
    } else if (step.type === 'quantity') {
      const val = selections[step.id] || 0;
      html += `
        <div class="step-quantity">
          <button class="qty-btn" data-action="dec">-</button>
          <span class="qty-value" id="qtyValue">${val}</span>
          <button class="qty-btn" data-action="inc">+</button>
        </div>
        <p class="qty-price">${formatPrice(step.pricePerUnit)} por ${step.unitLabel} &middot; Total: ${formatPrice(val * step.pricePerUnit)}</p>
      `;
    } else if (step.type === 'toggle') {
      const on = selections[step.id] || false;
      const priceLabel = step.priceLabel ? step.priceLabel : '';
      html += `
        <div class="step-toggle">
          <button class="toggle-btn${on ? ' active' : ''}" id="toggleBtn">
            <span class="toggle-track"><span class="toggle-thumb"></span></span>
            <span class="toggle-text">${on ? 'Si' : 'No'}</span>
          </button>
          <span class="toggle-price">${formatPrice(step.price)}${priceLabel}</span>
        </div>
      `;
    }

    quoterBody.innerHTML = html;
    attachStepListeners(step);
  }

  function attachStepListeners(step) {
    if (step.type === 'single-select') {
      quoterBody.querySelectorAll('.option-card').forEach(btn => {
        btn.addEventListener('click', () => {
          selections[step.id] = btn.dataset.value;
          renderStep();
        });
      });
    } else if (step.type === 'quantity') {
      quoterBody.querySelectorAll('.qty-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          let val = selections[step.id] || 0;
          if (btn.dataset.action === 'inc' && val < step.max) val++;
          if (btn.dataset.action === 'dec' && val > step.min) val--;
          selections[step.id] = val;
          renderStep();
        });
      });
    } else if (step.type === 'toggle') {
      const toggleBtn = document.getElementById('toggleBtn');
      toggleBtn.addEventListener('click', () => {
        selections[step.id] = !selections[step.id];
        renderStep();
      });
    }
  }

  function calculateTotal() {
    let subtotal = 0;
    const items = [];
    const visible = getVisibleSteps();

    visible.forEach(step => {
      if (step.id === 'plazo') return;

      if (step.type === 'single-select' && selections[step.id]) {
        const opt = step.options.find(o => o.id === selections[step.id]);
        if (opt && opt.price) {
          subtotal += opt.price;
          items.push({ label: step.title + ': ' + opt.label, price: opt.price });
        }
      } else if (step.type === 'quantity' && selections[step.id]) {
        const qty = selections[step.id];
        const total = qty * step.pricePerUnit;
        subtotal += total;
        items.push({ label: step.title + ': ' + qty + ' ' + step.unitLabel + '(s)', price: total });
      } else if (step.type === 'toggle' && selections[step.id]) {
        subtotal += step.price;
        items.push({ label: step.title, price: step.price });
      }
    });

    let multiplier = 1;
    let plazoLabel = 'Normal';
    const plazoStep = steps.find(s => s.id === 'plazo');
    if (plazoStep && selections['plazo']) {
      const plazoOpt = plazoStep.options.find(o => o.id === selections['plazo']);
      if (plazoOpt) {
        multiplier = plazoOpt.multiplier;
        plazoLabel = plazoOpt.label;
      }
    }

    const afterMultiplier = Math.round(subtotal * multiplier);
    const discount = Math.round(afterMultiplier * config.discountPercent / 100);
    const total = afterMultiplier - discount;

    return { items, subtotal, multiplier, plazoLabel, afterMultiplier, discount, total };
  }

  function renderSummary() {
    const calc = calculateTotal();

    let itemsHtml = '';
    calc.items.forEach(item => {
      itemsHtml += `
        <div class="summary-row">
          <span>${item.label}</span>
          <span>${formatPrice(item.price)}</span>
        </div>
      `;
    });
    summaryItems.innerHTML = itemsHtml;

    let totalsHtml = `
      <div class="summary-row subtotal">
        <span>Subtotal</span>
        <span>${formatPrice(calc.subtotal)}</span>
      </div>
    `;
    if (calc.multiplier !== 1) {
      totalsHtml += `
        <div class="summary-row">
          <span>Plazo: ${calc.plazoLabel}</span>
          <span>${calc.multiplier > 1 ? '+' : ''}${Math.round((calc.multiplier - 1) * 100)}%</span>
        </div>
        <div class="summary-row">
          <span>Subtotal ajustado</span>
          <span>${formatPrice(calc.afterMultiplier)}</span>
        </div>
      `;
    }
    totalsHtml += `
      <div class="summary-row discount">
        <span>${config.discountLabel} (${config.discountPercent}%)</span>
        <span>- ${formatPrice(calc.discount)}</span>
      </div>
      <div class="summary-row total">
        <span>TOTAL</span>
        <span>${formatPrice(calc.total)}</span>
      </div>
    `;
    summaryTotals.innerHTML = totalsHtml;

    // WhatsApp
    let msg = '*Cotizacion Parzik*\n\n';
    calc.items.forEach(item => {
      msg += `${item.label} - ${formatPrice(item.price)}\n`;
    });
    msg += `\nSubtotal: ${formatPrice(calc.subtotal)}`;
    if (calc.multiplier !== 1) {
      msg += `\nPlazo: ${calc.plazoLabel} (${calc.multiplier > 1 ? '+' : ''}${Math.round((calc.multiplier - 1) * 100)}%)`;
      msg += `\nSubtotal ajustado: ${formatPrice(calc.afterMultiplier)}`;
    }
    msg += `\n${config.discountLabel}: - ${formatPrice(calc.discount)}`;
    msg += `\n*TOTAL: ${formatPrice(calc.total)}*`;

    const encoded = encodeURIComponent(msg);
    btnWhatsapp.href = `https://wa.me/${config.whatsappNumber}?text=${encoded}`;
  }

  function showSummary() {
    document.querySelector('.quoter-card').style.display = 'none';
    quoterSummary.style.display = 'block';
    renderSummary();
  }

  function showQuoter() {
    document.querySelector('.quoter-card').style.display = 'block';
    quoterSummary.style.display = 'none';
  }

  btnNext.addEventListener('click', () => {
    const visible = getVisibleSteps();
    const step = visible[currentStepIndex];

    // Validate selection
    if (step.type === 'single-select' && !selections[step.id]) return;

    if (currentStepIndex < visible.length - 1) {
      currentStepIndex++;
      renderStep();
    } else {
      showSummary();
    }
  });

  btnPrev.addEventListener('click', () => {
    if (currentStepIndex > 0) {
      currentStepIndex--;
      renderStep();
    }
  });

  btnNewQuote.addEventListener('click', () => {
    currentStepIndex = 0;
    selections = {};
    showQuoter();
    renderStep();
  });

  // Init
  renderStep();
</script>

<style>
  .container {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  /* Page Hero (same pattern as servicios) */
  .page-hero {
    position: relative;
    padding: 140px var(--space-lg) var(--space-2xl);
    overflow: hidden;
    text-align: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .circle {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.08;
  }

  .circle-1 {
    width: 500px;
    height: 500px;
    background: var(--lime-green);
    top: -200px;
    left: -100px;
  }

  .circle-2 {
    width: 400px;
    height: 400px;
    background: var(--lime-green);
    bottom: -150px;
    right: -100px;
  }

  .page-hero .container {
    position: relative;
    z-index: 1;
  }

  .tag {
    color: var(--lime-green);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--space-sm);
  }

  .page-hero h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    margin-bottom: var(--space-sm);
  }

  .subtitle {
    color: rgba(255, 255, 255, 0.5);
    font-size: 1.0625rem;
    font-weight: 300;
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Cotizador section */
  .cotizador {
    padding: 0 0 var(--space-2xl);
  }

  .quoter-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: var(--space-xl);
  }

  /* Progress */
  .quoter-progress {
    margin-bottom: var(--space-lg);
  }

  .progress-bar {
    height: 4px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: var(--space-xs);
  }

  .progress-fill {
    height: 100%;
    background: var(--lime-green);
    border-radius: 2px;
    transition: width 0.3s ease;
    width: 10%;
  }

  .progress-text {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.8125rem;
    font-weight: 300;
  }

  /* Steps */
  .quoter-body {
    min-height: 260px;
  }

  .quoter-body :global(.step-title) {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: var(--space-xs);
  }

  .quoter-body :global(.step-desc) {
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.9375rem;
    font-weight: 300;
    margin-bottom: var(--space-lg);
  }

  /* Single select options */
  .quoter-body :global(.step-options) {
    display: grid;
    gap: var(--space-sm);
  }

  .quoter-body :global(.option-card) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-xs);
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: var(--space-md) var(--space-lg);
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s, transform 0.2s;
    color: var(--deep-white);
    font-family: var(--font-body);
    font-size: 1rem;
    text-align: left;
    width: 100%;
  }

  .quoter-body :global(.option-card:hover) {
    border-color: rgba(203, 232, 80, 0.2);
    background: rgba(255, 255, 255, 0.04);
    transform: translateY(-2px);
  }

  .quoter-body :global(.option-card.selected) {
    border-color: rgba(203, 232, 80, 0.4);
    background: rgba(203, 232, 80, 0.06);
  }

  .quoter-body :global(.option-label) {
    font-weight: 600;
  }

  .quoter-body :global(.option-price) {
    color: var(--lime-green);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.9375rem;
  }

  .quoter-body :global(.option-desc) {
    width: 100%;
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.8125rem;
    font-weight: 300;
  }

  /* Quantity */
  .quoter-body :global(.step-quantity) {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    justify-content: center;
    margin-bottom: var(--space-md);
  }

  .quoter-body :global(.qty-btn) {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.03);
    color: var(--deep-white);
    font-size: 1.5rem;
    font-family: var(--font-heading);
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }

  .quoter-body :global(.qty-btn:hover) {
    border-color: var(--lime-green);
    background: rgba(203, 232, 80, 0.06);
  }

  .quoter-body :global(.qty-value) {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 700;
    min-width: 60px;
    text-align: center;
  }

  .quoter-body :global(.qty-price) {
    text-align: center;
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.875rem;
    font-weight: 300;
  }

  /* Toggle */
  .quoter-body :global(.step-toggle) {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    justify-content: center;
  }

  .quoter-body :global(.toggle-btn) {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    background: none;
    border: none;
    cursor: pointer;
    color: var(--deep-white);
    font-family: var(--font-body);
    font-size: 1rem;
  }

  .quoter-body :global(.toggle-track) {
    display: block;
    width: 52px;
    height: 28px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 14px;
    position: relative;
    transition: background 0.2s;
  }

  .quoter-body :global(.toggle-btn.active .toggle-track) {
    background: var(--lime-green);
  }

  .quoter-body :global(.toggle-thumb) {
    display: block;
    width: 22px;
    height: 22px;
    background: var(--deep-white);
    border-radius: 50%;
    position: absolute;
    top: 3px;
    left: 3px;
    transition: transform 0.2s;
  }

  .quoter-body :global(.toggle-btn.active .toggle-thumb) {
    transform: translateX(24px);
  }

  .quoter-body :global(.toggle-text) {
    font-weight: 600;
    min-width: 24px;
  }

  .quoter-body :global(.toggle-price) {
    color: var(--lime-green);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.125rem;
  }

  /* Navigation */
  .quoter-nav {
    display: flex;
    justify-content: space-between;
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .btn-primary {
    display: inline-block;
    background: var(--lime-green);
    color: var(--deep-ocean);
    padding: 14px 32px;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.9375rem;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(203, 232, 80, 0.25);
  }

  .btn-secondary {
    display: inline-block;
    background: transparent;
    color: rgba(255, 255, 255, 0.6);
    padding: 14px 32px;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.9375rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    cursor: pointer;
    font-family: var(--font-body);
    transition: border-color 0.2s, color 0.2s;
  }

  .btn-secondary:hover {
    border-color: rgba(255, 255, 255, 0.3);
    color: var(--deep-white);
  }

  /* Summary */
  .summary-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: var(--space-xl);
  }

  .summary-card h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: var(--space-lg);
  }

  .summary-items :global(.summary-row) {
    display: flex;
    justify-content: space-between;
    padding: var(--space-xs) 0;
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.65);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .summary-totals {
    margin-top: var(--space-sm);
  }

  .summary-totals :global(.summary-row) {
    display: flex;
    justify-content: space-between;
    padding: var(--space-xs) 0;
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.65);
  }

  .summary-totals :global(.summary-row.subtotal) {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: var(--space-sm);
    font-weight: 600;
    color: var(--deep-white);
  }

  .summary-totals :global(.summary-row.discount) {
    color: var(--lime-green);
  }

  .summary-totals :global(.summary-row.total) {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: var(--space-sm);
    margin-top: var(--space-xs);
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--deep-white);
  }

  .summary-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-top: var(--space-xl);
    align-items: center;
