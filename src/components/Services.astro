---

---

<!-- Services section — displays the company's core offerings in a responsive card grid -->
<section id="servicios" class="services">
  <div class="container">
    <p class="section-tag" data-animate="fade-up">Lo que hacemos</p>
    <h2 data-animate="fade-up" data-delay="100">Servicios</h2>

    <!-- Card grid — stagger animation applied via data-stagger attribute -->
    <div class="services-grid" data-stagger>
      <div class="service-card">
        <div class="service-icon">
          <!-- Web development icon -->
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="16 18 22 12 16 6"></polyline>
            <polyline points="8 6 2 12 8 18"></polyline>
          </svg>
        </div>
        <h3>Desarrollo Web</h3>
        <p>Sitios y aplicaciones web rápidas, escalables y con tecnología moderna.</p>
      </div>

      <div class="service-card">
        <div class="service-icon">
          <!-- Custom software icon -->
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
            <line x1="8" y1="21" x2="16" y2="21"></line>
            <line x1="12" y1="17" x2="12" y2="21"></line>
          </svg>
        </div>
        <h3>Software a Medida</h3>
        <p>Sistemas y plataformas personalizadas para automatizar y escalar tu operación.</p>
      </div>

    </div>
  </div>
</section>

<style>
  /* Section background matches the deep ocean design token */
  .services {
    position: relative;
    padding: var(--space-2xl) var(--space-lg);
    background: var(--deep-ocean);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* Small uppercase label above the section heading */
  .section-tag {
    color: var(--lime-green);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-xs);
  }

  /* Fluid heading size — scales between 2rem and 2.75rem */
  h2 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    margin-bottom: var(--space-xl);
  }

  /* Auto-fit grid — collapses to a single column on small screens */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-md);
  }

  /* Subtle glass-style card with a hover border highlight */
  .service-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    padding: var(--space-lg);
    transition: border-color 0.2s, background 0.2s;
  }

  .service-card:hover {
    border-color: rgba(203, 232, 80, 0.2);
    background: rgba(255, 255, 255, 0.05);
  }

  /* Icon inherits lime-green accent color */
  .service-icon {
    color: var(--lime-green);
    margin-bottom: var(--space-sm);
  }

  h3 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: var(--space-xs);
  }

  /* Muted body text inside cards */
  .service-card p {
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.9375rem;
    line-height: 1.6;
    font-weight: 300;
  }
</style>
