</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px var(--space-lg) 160px;
    overflow: hidden;
    background: linear-gradient(135deg, #0A0A0A 0%, #111827 50%, #0A0A0A 100%);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .circle {
    position: absolute;
    border-radius: 50%;
    background: var(--lime-green);
    opacity: 0.06;
  }

  .circle-1 {
    width: 500px;
    height: 500px;
    top: -100px;
    right: -100px;
  }

  .circle-2 {
    width: 350px;
    height: 350px;
    bottom: 10%;
    left: -80px;
  }

  .circle-3 {
    width: 200px;
    height: 200px;
    top: 40%;
    right: 15%;
    opacity: 0.04;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 720px;
  }

  .hero-tag {
    display: inline-block;
    padding: 6px 16px;
    border: 1px solid rgba(203, 232, 80, 0.3);
    border-radius: 100px;
    font-size: 0.8125rem;
    color: var(--lime-green);
    font-weight: 600;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-md);
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: var(--space-md);
    color: var(--deep-white);
  }

  .highlight {
    color: var(--lime-green);
  }

  .hero-sub {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.6);
    max-width: 520px;
    margin: 0 auto var(--space-lg);
    line-height: 1.7;
    font-weight: 300;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--lime-green);
    color: var(--deep-ocean);
    padding: 14px 32px;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.9375rem;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(203, 232, 80, 0.25);
  }

  .btn-secondary {
    color: rgba(255, 255, 255, 0.7);
    padding: 14px 32px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 10px;
    font-weight: 500;
    font-size: 0.9375rem;
    transition: border-color 0.2s, color 0.2s;
  }

  .btn-secondary:hover {
    border-color: rgba(255, 255, 255, 0.4);
    color: var(--deep-white);
  }

  /* Laptop with scrolling screen */
  .hero-visual {
    position: relative;
    z-index: 5;
    margin-top: var(--space-xl);
    margin-bottom: -120px;
  }

  .laptop-wrapper {
    position: relative;
    width: min(520px, 80vw);
    margin: 0 auto;
  }

  .laptop-img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: auto;
    filter: drop-shadow(0 20px 60px rgba(0, 0, 0, 0.5)) brightness(1.7);
    pointer-events: none;
  }

  .laptop-screen-mask {
    position: absolute;
    top: 8%;
    left: 8.5%;
    width: 83.5%;
    height: 76.5%;
    z-index: 2;
    overflow: hidden;
    border-radius: 9px;
    background: #0A0A0A;
  }

  .screen-scroll {
    animation: scrollScreen 18s ease-in-out infinite alternate;
  }

  @keyframes scrollScreen {
    0%, 5% {
      transform: translateY(0);
    }
    95%, 100% {
      transform: translateY(-65%);
    }
  }

  /* E-commerce site styles */
  .ec {
    width: 100%;
    background: #fafaf9;
    font-family: 'Open Sans', sans-serif;
    color: #1a1a1a;
    font-size: 3.5px;
    line-height: 1.4;
  }

  .ec-topbar {
    background: #1a1a1a;
    color: #fff;
    text-align: center;
    padding: 2px;
    font-size: 2.5px;
    letter-spacing: 0.2px;
  }

  .ec-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 4px 8px;
    background: #fff;
    border-bottom: 1px solid #eee;
  }

  .ec-logo {
    font-family: 'Poppins', sans-serif;
    font-weight: 700;
    font-size: 5px;
    color: #8b6914;
    letter-spacing: 0.5px;
  }

  .ec-nav-links {
    display: flex;
    gap: 6px;
    font-size: 2.8px;
    color: #555;
  }

  .ec-nav-icons {
    display: flex;
    gap: 4px;
  }

  .ec-nav-icons svg {
    width: 5px;
    height: 5px;
  }

  .ec-hero {
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, #f5f0e8, #e8ddd0);
    padding: 10px 8px;
    gap: 8px;
  }

  .ec-hero-text {
    flex: 1;
  }

  .ec-badge {
    display: inline-block;
    background: #1a1a1a;
    color: #fff;
    padding: 1px 3px;
    border-radius: 1px;
    font-size: 2px;
    font-weight: 600;
    letter-spacing: 0.2px;
    margin-bottom: 3px;
  }

  .ec-title {
    font-family: 'Poppins', sans-serif;
    font-size: 7px;
    font-weight: 700;
    color: #1a1a1a;
    line-height: 1.1;
    margin-bottom: 2px;
  }

  .ec-subtitle {
    font-size: 2.8px;
    color: #666;
    margin-bottom: 5px;
    line-height: 1.5;
  }

  .ec-cta {
    display: inline-block;
    background: #1a1a1a;
    color: #fff;
    padding: 2.5px 7px;
    border-radius: 2px;
    font-size: 2.8px;
    font-weight: 600;
  }

  .ec-cta.sm {
    padding: 2px 5px;
    font-size: 2.5px;
  }

  .ec-hero-img {
    flex: 0 0 30%;
  }

  .ec-plant {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 6px;
    overflow: hidden;
  }

  .ec-plant img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ec-categories {
    padding: 8px;
  }

  .ec-section-title {
    font-family: 'Poppins', sans-serif;
    font-size: 4.5px;
    font-weight: 600;
    margin-bottom: 5px;
    color: #1a1a1a;
  }

  .ec-cat-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 4px;
  }

  .ec-cat {
    text-align: center;
    font-size: 2.5px;
    color: #555;
    font-weight: 500;
  }

  .ec-cat-img {
    width: 100%;
    height: 0;
    padding-bottom: 100%;
    border-radius: 50%;
    margin-bottom: 2px;
    overflow: hidden;
    position: relative;
  }

  .ec-cat-img img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ec-products {
    padding: 6px 8px 8px;
  }

  .ec-prod-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
  }

  .ec-product {
    background: #fff;
    border-radius: 3px;
    overflow: hidden;
    border: 1px solid #eee;
    display: flex;
    flex-direction: column;
  }

  .ec-prod-img {
    width: 100%;
    height: 0;
    padding-bottom: 100%;
    position: relative;
    overflow: hidden;
    background: #f5f5f0;
  }

  .ec-prod-img img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ec-sale {
    position: absolute;
    top: 2px;
    left: 2px;
    z-index: 1;
    background: #e53e3e;
    color: #fff;
    padding: 0.5px 2px;
    border-radius: 1px;
    font-size: 2px;
    font-weight: 700;
  }

  .ec-prod-name {
    padding: 2px 3px 0.5px;
    font-size: 2.8px;
    font-weight: 600;
    color: #1a1a1a;
  }

  .ec-prod-price {
    padding: 0.5px 3px 2px;
    font-size: 3px;
    font-weight: 700;
    color: #8b6914;
  }

  .ec-prod-price .old {
    color: #999;
    text-decoration: line-through;
    font-weight: 400;
    font-size: 2.5px;
    margin-right: 1px;
  }

  .ec-prod-btn {
    margin: 0 3px 3px;
    background: #1a1a1a;
    color: #fff;
    text-align: center;
    padding: 2px;
    border-radius: 1.5px;
    font-size: 2.5px;
    font-weight: 600;
  }

  .ec-banner {
    margin: 4px 8px 6px;
    background: linear-gradient(135deg, #1a1a1a, #2a2218);
    border-radius: 4px;
    padding: 10px 8px;
    color: #fff;
  }

  .ec-banner-title {
    font-family: 'Poppins', sans-serif;
    font-size: 5.5px;
    font-weight: 700;
    margin-bottom: 2px;
  }

  .ec-banner-sub {
    font-size: 2.8px;
    color: rgba(255,255,255,0.8);
    margin-bottom: 5px;
    line-height: 1.5;
  }

  .ec-banner .ec-cta {
    background: #fff;
    color: #8b6914;
  }

  .ec-testimonials {
    padding: 6px 8px 8px;
    background: #fff;
  }

  .ec-test-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
  }

  .ec-test {
    background: #fafaf9;
    border: 1px solid #eee;
    border-radius: 3px;
    padding: 5px;
  }

  .ec-stars {
    color: #d4a843;
    font-size: 3px;
    margin-bottom: 2px;
  }

  .ec-test-text {
    font-size: 2.5px;
    color: #444;
    line-height: 1.5;
    font-style: italic;
    margin-bottom: 2px;
  }

  .ec-test-author {
    font-size: 2px;
    color: #888;
    font-weight: 600;
  }

  .ec-newsletter {
    text-align: center;
    padding: 8px;
    background: #f5f0e8;
  }

  .ec-nl-title {
    font-family: 'Poppins', sans-serif;
    font-size: 4px;
    font-weight: 600;
    margin-bottom: 4px;
    color: #1a1a1a;
  }

  .ec-nl-form {
    display: flex;
    justify-content: center;
    gap: 3px;
  }

  .ec-input {
    background: #fff;
    border: 1px solid #ddd;
    border-radius: 2px;
    padding: 2px 5px;
    font-size: 2.5px;
    color: #999;
    min-width: 40px;
  }

  .ec-footer {
    background: #1a1a1a;
    color: #aaa;
    padding: 8px;
  }

  .ec-footer-cols {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 6px;
    margin-bottom: 5px;
  }

  .ec-footer-col {
    display: flex;
    flex-direction: column;
    gap: 1.5px;
    font-size: 2.5px;
  }

  .ec-footer-col .ec-logo {
    font-size: 4px;
    color: #fff;
  }

  .ec-footer-text {
    font-size: 2.5px;
    color: #777;
  }

  .ec-footer-title {
    font-weight: 700;
    color: #fff;
    font-size: 3px;
    margin-bottom: 1px;
  }

  .ec-footer-bottom {
    border-top: 1px solid #333;
    padding-top: 4px;
    font-size: 2px;
    color: #666;
    text-align: center;
  }

  .hero-curve {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 3;
    height: 280px;
  }

  .hero-curve svg {
    display: block;
    width: 100%;
    height: 160px;
  }

  .hero-curve-fill {
    display: block;
    width: 100%;
    height: 120px;
    background: var(--deep-ocean);
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: 100px;
    }

    .hero-sub {
      font-size: 1rem;
    }
  }
</style>
