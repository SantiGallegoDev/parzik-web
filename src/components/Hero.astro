---

<!-- Hero section — full-viewport landing block with tagline, CTA buttons, and laptop mockup -->
<section class="hero">
  <!-- Decorative background circles for ambient depth effect -->
  <div class="hero-bg">
    <div class="circle circle-1"></div>
    <div class="circle circle-2"></div>
    <div class="circle circle-3"></div>
  </div>

  <!-- Main headline, sub-copy, and CTA actions -->
  <div class="hero-content">
    <p class="hero-tag" data-animate="blur">Software & Soluciones Digitales</p>
    <h1 data-animate="fade-up" data-delay="100">Construimos tu<br /><span class="highlight">presencia digital</span></h1>
    <p class="hero-sub" data-animate="fade-up" data-delay="200">
      Desarrollo de software y soluciones digitales que impulsan tu negocio con precisión tecnológica.
    </p>
    <div class="hero-actions" data-animate="fade-up" data-delay="300">
      <a href="#contacto" class="btn-primary">Agenda una llamada</a>
      <a href="#servicios" class="btn-secondary">Ver servicios</a>
    </div>
  </div>

  <!-- Laptop mockup with an auto-scrolling screen screenshot -->
  <div class="hero-visual" data-animate="scale" data-delay="400">
    <div class="laptop-wrapper">
      <!-- Masked overlay that clips the scrolling content to the screen area -->
      <div class="laptop-screen-mask">
        <div class="screen-scroll">
          <img src="/shop/cocora-trimmed.jpg" alt="Cocora Coffee House" class="screen-capture" />
        </div>
      </div>
      <img src="/hero-laptop.png" alt="Parzik en laptop" class="laptop-img" />
    </div>
  </div>


  <!-- Wave divider that transitions into the next section background -->
  <div class="hero-curve">
    <svg viewBox="0 0 1440 160" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0 0C0 0 360 160 720 160C1080 160 1440 0 1440 0V160H0V0Z" fill="var(--deep-ocean)" />
    </svg>
    <div class="hero-curve-fill"></div>
  </div>
</section>

<style>
  /* Full-viewport hero with centered column layout */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px var(--space-lg) 160px;
    overflow: hidden;
    background: linear-gradient(135deg, #0A0A0A 0%, #111827 50%, #0A0A0A 100%);
  }

  /* Non-interactive background layer for decorative circles */
  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  /* Base style shared by all background circle elements */
  .circle {
    position: absolute;
    border-radius: 50%;
    background: var(--lime-green);
    opacity: 0.06;
  }

  /* Top-right large accent circle */
  .circle-1 {
    width: 500px;
    height: 500px;
    top: -100px;
    right: -100px;
  }

  /* Bottom-left mid accent circle */
  .circle-2 {
    width: 350px;
    height: 350px;
    bottom: 10%;
    left: -80px;
  }

  /* Center-right small accent circle — slightly more transparent */
  .circle-3 {
    width: 200px;
    height: 200px;
    top: 40%;
    right: 15%;
    opacity: 0.04;
  }

  /* Content block sits above background elements */
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 720px;
  }

  /* Pill-shaped category label above the main heading */
  .hero-tag {
    display: inline-block;
    padding: 6px 16px;
    border: 1px solid rgba(203, 232, 80, 0.3);
    border-radius: 100px;
    font-size: 0.8125rem;
    color: var(--lime-green);
    font-weight: 600;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-md);
  }

  /* Fluid heading size using clamp for responsive scaling */
  h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: var(--space-md);
    color: var(--deep-white);
  }

  /* Accent color applied to the emphasized heading span */
  .highlight {
    color: var(--lime-green);
  }

  /* Supporting copy beneath the main heading */
  .hero-sub {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.6);
    max-width: 520px;
    margin: 0 auto var(--space-lg);
    line-height: 1.7;
    font-weight: 300;
  }

  /* CTA button row — wraps on small screens */
  .hero-actions {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Primary CTA — solid lime button */
  .btn-primary {
    background: var(--lime-green);
    color: var(--deep-ocean);
    padding: 14px 32px;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.9375rem;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(203, 232, 80, 0.25);
  }

  /* Secondary CTA — ghost button with subtle border */
  .btn-secondary {
    color: rgba(255, 255, 255, 0.7);
    padding: 14px 32px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 10px;
    font-weight: 500;
    font-size: 0.9375rem;
    transition: border-color 0.2s, color 0.2s;
  }

  .btn-secondary:hover {
    border-color: rgba(255, 255, 255, 0.4);
    color: var(--deep-white);
  }

  /* Laptop mockup with auto-scrolling screen content */
  .hero-visual {
    position: relative;
    z-index: 5;
    margin-top: var(--space-xl);
    /* Negative margin pulls the mockup into the curve transition */
    margin-bottom: -120px;
  }

  /* Responsive wrapper caps the mockup width on large screens */
  .laptop-wrapper {
    position: relative;
    width: min(520px, 80vw);
    margin: 0 auto;
  }

  /* Laptop frame image layered above the screen content */
  .laptop-img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: auto;
    filter: drop-shadow(0 20px 60px rgba(0, 0, 0, 0.5)) brightness(1.7);
    pointer-events: none;
  }

  /* Clips the scrolling screenshot to the visible screen area of the laptop frame */
  .laptop-screen-mask {
    position: absolute;
    top: 8%;
    left: 8.5%;
    width: 83.5%;
    height: 76.5%;
    z-index: 2;
    overflow: hidden;
    border-radius: 9px;
    background: #0A0A0A;
  }

  /* Slow vertical scroll simulates browsing the showcase site */
  .screen-scroll {
    animation: scrollScreen 20s linear infinite alternate;
  }

  @keyframes scrollScreen {
    0%   { transform: translateY(0); }
    100% { transform: translateY(-86%); }
  }

  /* Screenshot fills the full mask width */
  .screen-capture {
    width: 100%;
    display: block;
  }

  /* Wave SVG + solid fill block that blends into the next section */
  .hero-curve {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 3;
    height: 280px;
  }

  .hero-curve svg {
    display: block;
    width: 100%;
    height: 160px;
  }

  /* Solid fill below the SVG wave to cover any sub-pixel gaps */
  .hero-curve-fill {
    display: block;
    width: 100%;
    height: 120px;
    background: var(--deep-ocean);
  }

  /* Mobile adjustments — reduce top padding and sub-copy size */
  @media (max-width: 768px) {
    .hero {
      padding-top: 100px;
    }

    .hero-sub {
      font-size: 1rem;
    }
  }
</style>
