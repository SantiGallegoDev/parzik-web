---

<nav class="navbar">
  <div class="navbar-inner">
    <a href="/" class="logo">
      <img src="/logo-parzik.png" alt="Parzik" class="logo-img" />
    </a>

    <div class="nav-links">
      <a href="/servicios">Servicios</a>
      <a href="/nosotros">Nosotros</a>
      <a href="/proyectos">Proyectos</a>
      <a href="/contacto" class="btn-cta">Contacto</a>
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: var(--space-sm) var(--space-lg);
    background: rgba(10, 10, 10, 0.8);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .navbar-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
  }

  .logo-img {
    height: 32px;
    width: auto;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .nav-links a {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.875rem;
    font-weight: 400;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: var(--deep-white);
  }

  .btn-cta {
    background: var(--lime-green);
    color: var(--deep-ocean) !important;
    padding: 8px 20px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.875rem;
    transition: opacity 0.2s;
  }

  .btn-cta:hover {
    opacity: 0.9;
  }

  @media (max-width: 768px) {
    .nav-links a:not(.btn-cta) {
      display: none;
    }
  }
</style>
