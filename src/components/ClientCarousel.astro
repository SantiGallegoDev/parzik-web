---
// Client logo data — logos are hosted on per-client S3 buckets
const clients = [
  { name: "Humboldt", logo: "https://asuntos-nacionales-e-internacionales-humboldt.s3.sa-east-1.amazonaws.com/thumbnail_humboldt_White_Logo_6ea6d4271b.png" },
  { name: "Luxury Patios", logo: "https://luxury-patios.s3.sa-east-1.amazonaws.com/LpWhiteLogo.png" },
  { name: "Bianca Dental", logo: "https://bianca-dental.s3.sa-east-1.amazonaws.com/biancaLogoWhite.png" },
  { name: "Lopez Pool Service", logo: "https://lopez-pool-service.s3.sa-east-1.amazonaws.com/lopezPoolServiceLogo.png" },
  { name: "La Cocina de Martina", logo: "https://la-cocina-de-martina.s3.sa-east-1.amazonaws.com/laCocinaDeMartinaLogo.png" },
  { name: "FitConnect Pro", logo: "https://fit-connect-pro.s3.sa-east-1.amazonaws.com/fitConnectWhiteLogo.png" },
  { name: "Luxor Barber", logo: "https://luxor-barber.s3.sa-east-1.amazonaws.com/luxorLogo.png" },
  { name: "The Printing Center", logo: "https://the-printing-center.s3.sa-east-1.amazonaws.com/thePrintingCenterLogoWhite.png" },
  { name: "Timbe Clean Solutions", logo: "https://jt-cleaning-services.s3.sa-east-1.amazonaws.com/timbe-clean-solutions-logo.png" },
  { name: "VH", logo: "https://jose-vicente-hernandez.s3.sa-east-1.amazonaws.com/VH_goldLogo.png" },
  { name: "NJ Printing", logo: "https://nj-printing-embroidery-llc.s3.sa-east-1.amazonaws.com/logo+NJ+Printing+2023.png" },
  { name: "Parzik", logo: "https://i.postimg.cc/DwByB6MD/Icono-blanco-1.png" },
  { name: "Cocora Coffee", logo: "https://the-cocora-coffee.s3.sa-east-1.amazonaws.com/cocoraCofeeHouseLogo.jpeg" },
];

// Split clients into two rows for the dual-track layout
const row1 = clients.slice(0, 7);
const row2 = clients.slice(7);
---

<section class="clients" data-animate="fade-up">
  <div class="clients-container">
    <p class="section-tag">Clientes</p>
    <h2>Empresas que <span class="highlight">confían en nosotros</span></h2>
    <p class="clients-sub">Más de 30 marcas han transformado su presencia digital con nosotros</p>
  </div>

  <div class="carousel-scene">
    <!-- Background ambient glow and decorative grid -->
    <div class="ambient-glow"></div>
    <div class="grid-floor"></div>

    <!-- Row 1 — scrolls left -->
    <div class="carousel-row">
      <div class="carousel-fade carousel-fade--left"></div>
      <div class="carousel-fade carousel-fade--right"></div>
      <!-- Items duplicated 4x to ensure seamless loop at all viewport widths -->
      <div class="carousel-track track-left">
        {[...row1, ...row1, ...row1, ...row1].map((client) => (
          <div class="carousel-card">
            <div class="card-glow"></div>
            <div class="card-inner">
              <img src={client.logo} alt={client.name} loading="lazy" />
            </div>
            <span class="card-label">{client.name}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Row 2 — scrolls right, offset timing for visual depth -->
    <div class="carousel-row">
      <div class="carousel-fade carousel-fade--left"></div>
      <div class="carousel-fade carousel-fade--right"></div>
      <!-- Items duplicated 4x to ensure seamless loop at all viewport widths -->
      <div class="carousel-track track-right">
        {[...row2, ...row2, ...row2, ...row2].map((client) => (
          <div class="carousel-card">
            <div class="card-glow"></div>
            <div class="card-inner">
              <img src={client.logo} alt={client.name} loading="lazy" />
            </div>
            <span class="card-label">{client.name}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll('.carousel-card');

    cards.forEach((card) => {
      // 3D tilt effect — rotates the card based on cursor position relative to its center
      card.addEventListener('mousemove', (e) => {
        const el = card as HTMLElement;
        const rect = el.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;

        // Normalize offset to [-1, 1] range and apply max rotation of 8deg
        const rotateX = ((y - centerY) / centerY) * -8;
        const rotateY = ((x - centerX) / centerX) * 8;

        el.style.transform = `perspective(600px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.05)`;

        // Move radial glow to follow the cursor within the card
        const glow = el.querySelector('.card-glow') as HTMLElement;
        if (glow) {
          glow.style.background = `radial-gradient(circle at ${x}px ${y}px, rgba(203,232,80,0.15), transparent 60%)`;
          glow.style.opacity = '1';
        }
      });

      // Reset transform and hide glow when cursor leaves
      card.addEventListener('mouseleave', () => {
        const el = card as HTMLElement;
        el.style.transform = '';
        const glow = el.querySelector('.card-glow') as HTMLElement;
        if (glow) {
          glow.style.opacity = '0';
        }
      });
    });
  });
</script>

<style>
  .clients {
    padding: var(--space-2xl) 0;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    overflow: hidden;
    position: relative;
  }

  .clients-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 var(--space-lg);
    text-align: center;
    margin-bottom: var(--space-xl);
    position: relative;
    z-index: 2;
  }

  .section-tag {
    color: var(--lime-green);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: var(--space-xs);
  }

  .clients h2 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    margin-bottom: var(--space-xs);
  }

  .highlight {
    color: var(--lime-green);
  }

  .clients-sub {
    color: rgba(255, 255, 255, 0.4);
    font-size: 1rem;
    font-weight: 300;
  }

  /* ── Scene ── */
  .carousel-scene {
    position: relative;
    perspective: 1200px;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .ambient-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 300px;
    background: radial-gradient(ellipse, rgba(203, 232, 80, 0.06) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  /* Perspective grid at the bottom of the scene for depth */
  .grid-floor {
    position: absolute;
    bottom: -40px;
    left: -10%;
    right: -10%;
    height: 120px;
    background:
      linear-gradient(to bottom, transparent 0%, rgba(203, 232, 80, 0.02) 100%),
      repeating-linear-gradient(90deg, rgba(203, 232, 80, 0.03) 0px, rgba(203, 232, 80, 0.03) 1px, transparent 1px, transparent 80px),
      repeating-linear-gradient(0deg, rgba(203, 232, 80, 0.03) 0px, rgba(203, 232, 80, 0.03) 1px, transparent 1px, transparent 80px);
    mask-image: linear-gradient(to bottom, transparent, black 40%);
    -webkit-mask-image: linear-gradient(to bottom, transparent, black 40%);
    transform: perspective(400px) rotateX(40deg);
    pointer-events: none;
    z-index: 0;
  }

  /* ── Row ── */
  .carousel-row {
    position: relative;
    z-index: 1;
  }

  /* Edge fade overlays to soften the track at both sides */
  .carousel-fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 150px;
    z-index: 3;
    pointer-events: none;
  }

  .carousel-fade--left {
    left: 0;
    background: linear-gradient(to right, var(--deep-ocean) 0%, transparent 100%);
  }

  .carousel-fade--right {
    right: 0;
    background: linear-gradient(to left, var(--deep-ocean) 0%, transparent 100%);
  }

  /* ── Track ── */
  .carousel-track {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    width: max-content;
    padding: var(--space-sm) 0;
  }

  .track-left {
    animation: slide-left 45s linear infinite;
  }

  .track-right {
    animation: slide-right 50s linear infinite;
  }

  /* Pause animation on hover so users can inspect a logo */
  .carousel-track:hover {
    animation-play-state: paused;
  }

  /* Translate exactly 50% — works because the list is duplicated to create a seamless loop */
  @keyframes slide-left {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes slide-right {
    0% { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }

  /* ── Card ── */
  .carousel-card {
    flex-shrink: 0;
    position: relative;
    width: 180px;
    height: 100px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(255, 255, 255, 0.07);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    cursor: pointer;
    transition: transform 0.3s ease-out, border-color 0.4s, box-shadow 0.4s, background 0.4s;
    will-change: transform;
    transform-style: preserve-3d;
  }

  /* Gradient border drawn via pseudo-element mask technique */
  .carousel-card::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 17px;
    padding: 1px;
    background: linear-gradient(135deg, rgba(203, 232, 80, 0), rgba(203, 232, 80, 0));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    transition: background 0.5s;
    pointer-events: none;
  }

  .carousel-card:hover::before {
    background: linear-gradient(135deg, rgba(203, 232, 80, 0.4), rgba(203, 232, 80, 0.05), rgba(203, 232, 80, 0.3));
  }

  .carousel-card:hover {
    border-color: rgba(203, 232, 80, 0.3);
    box-shadow:
      0 0 30px rgba(203, 232, 80, 0.08),
      0 10px 40px rgba(0, 0, 0, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    background: rgba(255, 255, 255, 0.05);
  }

  /* Cursor-tracking radial glow — position is set via JS on mousemove */
  .card-glow {
    position: absolute;
    inset: 0;
    border-radius: 16px;
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
    z-index: 0;
  }

  .card-inner {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Logos default to desaturated; restore color on hover */
  .carousel-card img {
    max-width: 120px;
    max-height: 45px;
    object-fit: contain;
    filter: grayscale(100%) brightness(0.6);
    opacity: 0.45;
    transition: filter 0.5s, opacity 0.5s;
  }

  .carousel-card:hover img {
    filter: grayscale(0%) brightness(1) drop-shadow(0 0 8px rgba(203, 232, 80, 0.2));
    opacity: 1;
  }

  /* Client name — hidden by default, fades in on hover */
  .card-label {
    position: relative;
    z-index: 1;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0);
    transition: color 0.4s;
  }

  .carousel-card:hover .card-label {
    color: rgba(255, 255, 255, 0.5);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .carousel-fade {
      width: 60px;
    }

    .carousel-card {
      width: 140px;
      height: 80px;
    }

    .carousel-card img {
      max-width: 95px;
      max-height: 36px;
    }

    .carousel-track {
      gap: var(--space-md);
    }

    /* Faster scroll on mobile to compensate for narrower viewport */
    .track-left {
      animation-duration: 30s;
    }

    .track-right {
      animation-duration: 35s;
    }

    /* Grid floor is a decorative-only element — hidden on mobile for performance */
    .grid-floor {
      display: none;
    }

    .card-label {
      display: none;
    }
  }
</style>
