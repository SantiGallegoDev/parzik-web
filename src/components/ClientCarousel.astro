---
const clients = [
  { name: "Humboldt", logo: "https://asuntos-nacionales-e-internacionales-humboldt.s3.sa-east-1.amazonaws.com/thumbnail_humboldt_White_Logo_6ea6d4271b.png" },
  { name: "Luxury Patios", logo: "https://luxury-patios.s3.sa-east-1.amazonaws.com/LpWhiteLogo.png" },
  { name: "Bianca Dental", logo: "https://bianca-dental.s3.sa-east-1.amazonaws.com/biancaLogoWhite.png" },
  { name: "Lopez Pool Service", logo: "https://lopez-pool-service.s3.sa-east-1.amazonaws.com/lopezPoolServiceLogo.png" },
  { name: "La Cocina de Martina", logo: "https://la-cocina-de-martina.s3.sa-east-1.amazonaws.com/laCocinaDeMartinaLogo.png" },
  { name: "FitConnect Pro", logo: "https://fit-connect-pro.s3.sa-east-1.amazonaws.com/fitConnectWhiteLogo.png" },
  { name: "Luxor Barber", logo: "https://luxor-barber.s3.sa-east-1.amazonaws.com/luxorLogo.png" },
  { name: "The Printing Center", logo: "https://the-printing-center.s3.sa-east-1.amazonaws.com/thePrintingCenterLogoWhite.png" },
  { name: "Timbe Clean Solutions", logo: "https://jt-cleaning-services.s3.sa-east-1.amazonaws.com/timbe-clean-solutions-logo.png" },
  { name: "VH", logo: "https://jose-vicente-hernandez.s3.sa-east-1.amazonaws.com/VH_goldLogo.png" },
  { name: "NJ Printing", logo: "https://nj-printing-embroidery-llc.s3.sa-east-1.amazonaws.com/logo+NJ+Printing+2023.png" },
  { name: "Parzik", logo: "https://i.postimg.cc/DwByB6MD/Icono-blanco-1.png" },
  { name: "Cocora Coffee", logo: "https://the-cocora-coffee.s3.sa-east-1.amazonaws.com/cocoraCofeeHouseLogo.jpeg" },
];
---

<section class="clients" data-animate="fade-up">
  <div class="clients-container">
    <p class="section-tag">Clientes</p>
    <h2>Empresas que <span class="highlight">confían en nosotros</span></h2>
  </div>

  <div class="carousel-wrapper">
    <div class="carousel-fade carousel-fade--left"></div>
    <div class="carousel-fade carousel-fade--right"></div>

    <div class="carousel-track">
      {/* Render logos twice for seamless infinite loop */}
      {[...clients, ...clients].map((client) => (
        <div class="carousel-item">
          <img src={client.logo} alt={client.name} loading="lazy" />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .clients {
    padding: var(--space-2xl) 0;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    overflow: hidden;
  }

  .clients-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 var(--space-lg);
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .section-tag {
    color: var(--lime-green);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: var(--space-xs);
  }

  .clients h2 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    margin-bottom: var(--space-sm);
  }

  .highlight {
    color: var(--lime-green);
  }

  .carousel-wrapper {
    position: relative;
    width: 100%;
  }

  .carousel-fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 120px;
    z-index: 2;
    pointer-events: none;
  }

  .carousel-fade--left {
    left: 0;
    background: linear-gradient(to right, var(--deep-ocean), transparent);
  }

  .carousel-fade--right {
    right: 0;
    background: linear-gradient(to left, var(--deep-ocean), transparent);
  }

  .carousel-track {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    width: max-content;
    animation: scroll 40s linear infinite;
  }

  .carousel-track:hover {
    animation-play-state: paused;
  }

  .carousel-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 160px;
    height: 80px;
    padding: var(--space-sm);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition: border-color 0.4s, background 0.4s, transform 0.4s;
  }

  .carousel-item:hover {
    border-color: rgba(203, 232, 80, 0.25);
    background: rgba(255, 255, 255, 0.06);
    transform: translateY(-4px);
  }

  .carousel-item img {
    max-width: 120px;
    max-height: 50px;
    object-fit: contain;
    filter: grayscale(100%) brightness(0.7);
    opacity: 0.5;
    transition: filter 0.4s, opacity 0.4s;
  }

  .carousel-item:hover img {
    filter: grayscale(0%) brightness(1);
    opacity: 1;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 768px) {
    .carousel-fade {
      width: 60px;
    }

    .carousel-item {
      width: 130px;
      height: 65px;
    }

    .carousel-item img {
      max-width: 100px;
      max-height: 40px;
    }

    .carousel-track {
      gap: var(--space-md);
      animation-duration: 30s;
    }
  }
</style>
