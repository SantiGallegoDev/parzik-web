---
// Base layout used across all pages — handles meta tags, fonts, and global styles
import ScrollAnimations from '../components/ScrollAnimations.astro';

// Props: title — page-specific title injected into <head>
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Parzik - Agencia de desarrollo de software y soluciones digitales" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Preconnect to Google Fonts to reduce latency -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Poppins for headings, Open Sans for body text -->
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600&family=Poppins:wght@500;600;700&display=swap" rel="stylesheet" />

    <title>{title}</title>
  </head>
  <body>
    <!-- Page content injected here by each route -->
    <slot />
    <!-- Scroll-triggered animation handler, runs after content mounts -->
    <ScrollAnimations />
  </body>
</html>

<style is:global>
  /* CSS reset — normalize box model and remove default spacing */
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  /* Design tokens — colors, typography, and spacing scale */
  :root {
    --deep-ocean: #0A0A0A;
    --lime-green: #CBE850;
    --gray-bone: #F3F4F6;
    --deep-white: #FFFFFF;

    --font-heading: 'Poppins', sans-serif;
    --font-body: 'Open Sans', sans-serif;

    --space-xs: 8px;
    --space-sm: 16px;
    --space-md: 24px;
    --space-lg: 32px;
    --space-xl: 48px;
    --space-2xl: 64px;
  }

  html {
    scroll-behavior: smooth;
  }

  /* Base body styles — dark background with antialiased text rendering */
  body {
    font-family: var(--font-body);
    background-color: var(--deep-ocean);
    color: var(--deep-white);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  /* Headings use Poppins with tighter line height for display use */
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
    line-height: 1.2;
  }

  /* Global link style — accent color, no underline by default */
  a {
    color: var(--lime-green);
    text-decoration: none;
  }

  /* Prevent images from overflowing their containers */
  img {
    max-width: 100%;
    display: block;
  }
</style>
